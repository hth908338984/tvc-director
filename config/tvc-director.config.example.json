{
  "project": {
    "name": "demo-open-ear-headphones",
    "rootDir": "./demo-open-ear-headphones",
    "outputDir": "./demo-open-ear-headphones/renders"
  },
  "image": {
    "provider": "gemini-image",
    "apiKeyEnv": "GEMINI_API_KEY",
    "model": "gemini-3-pro-image-preview",
    "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent",
    "responseModalities": ["TEXT", "IMAGE"],
    "promptFiles": {
      "productMultiview": "assets/prompts/product-multiview.md",
      "storyboardGrid": "keyframes/prompts/grid-01-product-breakdown.md"
    },
    "outputs": {
      "productMultiview": "product-multiview.png",
      "storyboardGrid": "storyboard-grid.png"
    }
  },
  "video": {
    "provider": "http-task",
    "enabled": false,
    "apiKeyEnv": "SEEDANCE_API_KEY",
    "model": "doubao-seedance-2-0-260128",
    "promptFile": "video-scripts/segment-01-product-breakdown.md",
    "imageReferenceMode": "dataUrl",
    "submit": {
      "method": "POST",
      "endpoint": "https://YOUR_VIDEO_PROVIDER_ENDPOINT/v1/video/generations",
      "headers": {
        "Authorization": "Bearer {apiKey}",
        "Content-Type": "application/json"
      },
      "body": {
        "model": "{model}",
        "prompt": "{videoPrompt}",
        "duration": 15,
        "resolution": "1080p",
        "fps": 24,
        "images": ["{storyboardImage}", "{productImage}"]
      },
      "taskIdPath": "id"
    },
    "poll": {
      "method": "GET",
      "endpoint": "https://YOUR_VIDEO_PROVIDER_ENDPOINT/v1/video/generations/{taskId}",
      "headers": {
        "Authorization": "Bearer {apiKey}"
      },
      "intervalMs": 10000,
      "timeoutMs": 900000,
      "statusPath": "status",
      "successValues": ["succeeded", "success", "completed"],
      "failureValues": ["failed", "error", "cancelled"],
      "videoUrlPath": "output.video_url"
    },
    "output": "final-video.mp4"
  }
}
